# ──────────────────────────────────────────────────────────────────────────────
# PASALO.app — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real a git.
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# Firebase — Configuración del proyecto (obtener en Firebase Console)
# ⚠️  REGENERAR la apiKey si fue expuesta públicamente
# ──────────────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_project_id
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
VITE_FIREBASE_APP_ID=tu_app_id
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_ID=tu_database_id

# reCAPTCHA v3 — Firebase App Check
# Obtener en: https://console.firebase.google.com → App Check → reCAPTCHA v3
VITE_RECAPTCHA_SITE_KEY=tu_recaptcha_site_key_aqui

# Firebase Cloud Messaging — VAPID Key para push notifications en web
# Obtener en: Firebase Console → Configuración del proyecto → Cloud Messaging → Certificados web push
VITE_FIREBASE_VAPID_KEY=tu_vapid_key_aqui

# Sentry — Monitoreo de errores en producción (opcional pero recomendado)
# Crear proyecto en: https://sentry.io → Settings → Client Keys → DSN
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxx@o000000.ingest.sentry.io/0000000

# ──────────────────────────────────────────────────────────────────────────────
# CLOUD FUNCTIONS — Solo para Firebase Functions (NO exponer en el frontend)
# Configurar como secret en Firebase:
#   firebase functions:secrets:set GEMINI_API_KEY
# ──────────────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY=tu_gemini_api_key_aqui   ← solo en functions via Firebase Secrets
